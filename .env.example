# ─── Foundry VTT Relay ─────────────────────────────────────────────────
# URL of the relay server (Node.js relay proxy for Foundry VTT)
# Example: http://relay-server:8642 or https://relay.example.com
RELAY_URL=http://localhost:8642

# API key for the relay server (if authentication is enabled)
# Leave empty if the relay does not require a key
RELAY_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────
# Port the app listens on (default: 3000)
PORT=3000
